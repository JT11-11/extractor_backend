# Neon Postgres (gridai project)
DATABASE_URL=postgresql://neondb_owner:...@ep-square-thunder-aodggaj1-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# Neon Auth (Better Auth) — the auth base URL provisioned for the gridai project
NEON_AUTH_BASE_URL=https://ep-square-thunder-aodggaj1.neonauth.c-2.ap-southeast-1.aws.neon.tech/neondb/auth

# Ollama Cloud
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=kimi-k2.6:cloud
OLLAMA_TIMEOUT_SECONDS=240
EXTRACTION_PAGES_PER_REQUEST=4
EXTRACTION_MAX_PAGES=21
EXTRACTION_RENDER_DPI=120

# Resend (get an API key at https://resend.com)
RESEND_API_KEY=re_...
# Must be a verified domain/email in your Resend account (or use onboarding@resend.dev for sandbox)
RESEND_FROM=Bank Statement Converter <notifications@yourdomain.com>

# Vercel frontend URL (used in email links)
FRONTEND_URL=https://your-app.vercel.app

# CORS allowed origin(s), comma-separated
FRONTEND_ORIGIN=https://your-app.vercel.app,http://localhost:3000
